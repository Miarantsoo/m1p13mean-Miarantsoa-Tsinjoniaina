# Copiez ce fichier en .env et remplissez les valeurs
# cp env.example .env

# ENVIRONNEMENT
NODE_ENV=development

# MONGODB
MONGO_ROOT_USERNAME=admin
MONGO_ROOT_PASSWORD=admin123
MONGO_DATABASE=meandb

# BACKEND
BACKEND_PORT=3000
JWT_SECRET=votre_secret_jwt_a_changer
JWT_EXPIRES_IN=7d

# FRONTEND
FRONTEND_PORT=4200

# URLS (ajustez selon votre environnement)
# En développement
CORS_ORIGIN=http://localhost:4200
API_URL=http://localhost:3000

# En production, changez ces valeurs :
# CORS_ORIGIN=https://votredomaine.com
# API_URL=https://api.votredomaine.com
